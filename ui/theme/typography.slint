// ============================================
// KERNEL_OS Theme — Typography Constants
// ============================================

export global KernelTypo {
    out property <length> size-xs:    10px;
    out property <length> size-sm:    12px;
    out property <length> size-base:  14px;
    out property <length> size-lg:    16px;
    out property <length> size-xl:    20px;
    out property <length> size-2xl:   28px;
    out property <length> size-3xl:   36px;
    out property <length> size-4xl:   48px;
}
