// ============================================
// KERNEL_OS Theme — Color Palette
// Dark cyberpunk / kernel terminal aesthetic
// ============================================

export global KernelColors {
    // Backgrounds
    out property <color> bg-deep:       #0d1117;
    out property <color> bg-card:       #161b22;
    out property <color> bg-elevated:   #1c2333;
    out property <color> bg-hover:      #21262d;
    out property <color> bg-input:      #0d1117;

    // Accents
    out property <color> accent-cyan:   #38bdf8;
    out property <color> accent-green:  #4ade80;
    out property <color> accent-yellow: #fbbf24;
    out property <color> accent-red:    #f87171;
    out property <color> accent-orange: #fb923c;

    // Text
    out property <color> text-primary:  #e6edf3;
    out property <color> text-secondary:#8b949e;
    out property <color> text-muted:    #484f58;
    out property <color> text-accent:   #38bdf8;

    // Borders
    out property <color> border-default:#30363d;
    out property <color> border-accent: #38bdf850;
    out property <color> border-focus:  #38bdf8;

    // State colors
    out property <color> state-running: #38bdf8;
    out property <color> state-ready:   #4ade80;
    out property <color> state-blocked: #fbbf24;
    out property <color> state-terminated: #484f58;
    out property <color> state-new:     #a78bfa;

    // Gantt chart process colors
    out property <color> gantt-1: #38bdf8;
    out property <color> gantt-2: #4ade80;
    out property <color> gantt-3: #fb923c;
    out property <color> gantt-4: #fbbf24;
    out property <color> gantt-5: #a78bfa;
    out property <color> gantt-6: #f87171;
    out property <color> gantt-7: #2dd4bf;
    out property <color> gantt-8: #e879f9;
    out property <color> gantt-9: #60a5fa;
    out property <color> gantt-10: #34d399;
}
